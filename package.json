{
  "name": "ownerpilot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run typecheck",
    "test": "node scripts/run_tests.mjs",
    "ci:verify-locked-prose": "tsx scripts/ci/verify_locked_prose.ts",
    "ci:verify-fetch-binding": "node scripts/ci/check_fetch_binding.mjs",
    "ci:verify-classifier-lock": "node scripts/ci/verify_classifier_audit_no_input_text.mjs",
    "ci:verify-no-live-cliff": "node scripts/ci/verify_no_live_cliff_schedule.mjs",
    "ci:verify-geocode-failure-event": "node scripts/ci/verify_geocode_failure_event_no_user_content.mjs",
    "ci:verify-no-operator-secrets": "node scripts/ci/verify_no_operator_secrets.mjs",
    "ci:typecheck-edge": "tsc -p tsconfig.edge.json",
    "build:edge-core": "node scripts/build_edge_core.mjs",
    "build:parcel-health-core": "node scripts/build_parcel_health_core.mjs",
    "ci:verify-edge-core-sync": "npm run build:edge-core && git diff --exit-code supabase/functions/rtc-refresh/_core/",
    "ci:verify-parcel-health-core-sync": "npm run build:parcel-health-core && git diff --exit-code supabase/functions/parcel-health/_core/",
    "lockedprose:verify": "tsx scripts/ci/verify_locked_prose.ts",
    "lockedprose:hash": "node scripts/lockedprose_hash.mjs",
    "ci:test-locked-prose-guard": "node scripts/ci/verify_locked_prose.test.mjs",
    "ci:verify-banned-terms": "node scripts/ci/check_banned_terms.mjs",
    "ci:verify-mirror-denylist": "node scripts/ci/check_mirror_denylist.mjs",
    "ci:verify-no-preconsent-analytics": "node scripts/ci/check_no_preconsent_analytics.mjs",
    "synthetic:a14:503": "tsx scripts/synthetic/a14_503_enqueue_drain_resolve.ts",
    "synthetic:a14:exhaust": "tsx scripts/synthetic/a14_exhausted_retry.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@stripe/stripe-js": "^9.6.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.4",
    "stripe": "^22.1.1",
    "@notionhq/client": "^2.2.15"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "supabase": "^2.107.0",
    "tailwindcss": "^4",
    "tsx": "^4",
    "typescript": "^5",
    "@playwright/test": "^1.48.0"
  }

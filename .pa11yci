{
  "//": "Marketing Tranche 1 slice 5 — Pa11y CI a11y gate on the 6 marketing routes. Pa11y runs axe-core + HTML_CodeSniffer (WCAG2AA) under the hood, so this satisfies the axe-core requirement without a TypeScript import. Runs in CI: the CI job serves a build with MARKETING_TRANCHE1=true (routes 404 when the flag is off), then runs `pa11y-ci`.",
  "defaults": {
    "standard": "WCAG2AA",
    "runners": ["axe", "htmlcs"],
    "timeout": 30000,
    "wait": 500
  },
  "urls": [
    "http://localhost:3000/california-3-day-notice",
    "http://localhost:3000/tenant-behind-on-rent-california",
    "http://localhost:3000/serve-and-track-3-day-notice",
    "http://localhost:3000/photo-proof-of-posting",
    "http://localhost:3000/riskpath-records",
    "http://localhost:3000/los-angeles-3-day-notice"
  ]
}

#!/bin/sh
# SYSTEM_PROMPT lock guard — pre-commit (drift ruling 2026-06-06 §4).
#
# Blocks a commit that changes the help-chatbox system prompt away from its
# locked baseline without a deliberate re-lock. The prompt is attorney-gated;
# this is the prompt-equivalent of the V4_WORDING_SIGNED_OFF flag.
#
# Runs only when the chat route is part of the commit (cheap, no noise on
# unrelated commits). Checks the on-disk route.ts; CI re-checks the committed
# tree and is the authoritative gate (a `--no-verify` local bypass cannot merge).
#
# Install once:  git config core.hooksPath scripts/hooks
# (Note: core.hooksPath replaces .git/hooks — move any existing hooks here.)

if git diff --cached --name-only | grep -q '^app/api/chat/route\.ts$'; then
  node scripts/check_system_prompt_lock.mjs || {
    echo ""
    echo "Commit blocked: app/api/chat/route.ts changes the SYSTEM_PROMPT baseline."
    echo "If this change is attorney-reviewed, re-lock it (see the message above),"
    echo "stage app/api/chat/system_prompt.lock.json, and commit again."
    echo "To bypass locally (CI will still enforce): git commit --no-verify"
    exit 1
  }
fi

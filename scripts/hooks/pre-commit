#!/bin/sh
# Prompt-safety guards — pre-commit (drift ruling 2026-06-06 §4; correction 2026-06-07 §3.2).
#
# Two coupled guards, run only when the relevant files are part of the commit:
#   1. SYSTEM_PROMPT hash-lock  — any prompt change must be a deliberate attorney re-lock.
#   2. DOCUMENTS sunset tripwire — flipping the broker-workflow-live flag while the
#      interim notice-response language is still deployed is blocked.
# CI re-runs both and is the authoritative gate (a local --no-verify cannot merge).
#
# Install once:  git config core.hooksPath scripts/hooks
# (core.hooksPath replaces .git/hooks — move any existing hooks here.)

STAGED=$(git diff --cached --name-only)

if echo "$STAGED" | grep -q '^app/api/chat/route\.ts$'; then
  node scripts/check_system_prompt_lock.mjs || {
    echo ""
    echo "Commit blocked: SYSTEM_PROMPT changed. If attorney-reviewed, re-lock and stage"
    echo "lib/chat/persona.lock.json, then commit again (--no-verify bypasses locally; CI still enforces)."
    exit 1
  }
fi

if echo "$STAGED" | grep -qE '^(app/api/chat/route\.ts|lib/flow/templateVersion\.ts)$'; then
  node scripts/check_documents_sunset.mjs || {
    echo ""
    echo "Commit blocked: DOCUMENTS interim-language sunset gate (see message above)."
    exit 1
  }
fi

if echo "$STAGED" | grep -qE '^lib/chat/(classifier_prompt\.json|classifierPrompt\.ts)$'; then
  node scripts/check_classifier_prompt_lock.mjs || {
    echo ""
    echo "Commit blocked: CLASSIFIER_PROMPT changed. Attorney re-review required (see message above)."
    exit 1
  }
fi

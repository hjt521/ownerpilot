# OwnerPilot env var reference (partial — parcel-health alerting only).
# Real values are injected at deploy; never commit secrets.

# Parcel-health alerting (Workstream B, slice 2)
PARCEL_HEALTH_ALERT_EMAIL=<recipient-address>
PARCEL_HEALTH_ALERT_FROM=alerts@notifications.ownerpilot.ai
RESEND_API_KEY=<broker-injected-at-deploy>   # never commit; credential rail

# Invocation secret for the parcel-health Edge Function. Boot-validated; the function
# refuses to start if unset. Sent by the cron (future slice) as the x-parcel-health-secret
# request header (custom header, NOT Authorization). Generated per environment; never committed.
PARCEL_HEALTH_PROBE_SECRET=<32-byte-random-placeholder>

# --- Notion automation mirror (Lane 7 §P) ---
# Internal Notion integration token + target database id for the off-platform automation mirror.
# The mirror scrubs PII (A15 denylist) before any write. Server-only; never committed.
NOTION_TOKEN=<notion-internal-integration-token>
NOTION_AUTOMATION_DB_ID=<notion-database-id>
# Shared secret the /api/automation/log endpoint requires (x-automation-secret header). Server-only.
AUTOMATION_LOG_SECRET=<32-byte-random-placeholder>
# Shared secret Vercel Cron sends to the cron routes (geocode-audit, mirror-queue-drain/-depth-check).
CRON_SECRET=<32-byte-random-placeholder>

# --- Lane 6 analytics / consent (GA4 via consent-gated GTM + Cookiebot Path A) ---
# Lane 6 Analytics §Q — append to .env.example (master prompt §6). All server-only except the NEXT_PUBLIC_ ones.
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-83W9QCF4PQ
NEXT_PUBLIC_COOKIEBOT_CBID=<from Cookiebot admin — placeholder OK for PR; broker provisions real CBID before prod flip>
GA4_API_SECRET=<from GA4 admin — server-only, NO NEXT_PUBLIC_ prefix>

# --- Lane 5 Decision 2 broker-confirm ---
# Shared secret the broker /resolve endpoint requires (operator-held; server-only).
BROKER_RESOLVE_SECRET=<32-byte-random-placeholder>

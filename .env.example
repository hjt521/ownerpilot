# OwnerPilot env var reference (partial — parcel-health alerting only).
# Real values are injected at deploy; never commit secrets.

# Parcel-health alerting (Workstream B, slice 2)
PARCEL_HEALTH_ALERT_EMAIL=<recipient-address>
PARCEL_HEALTH_ALERT_FROM=alerts@notifications.ownerpilot.ai
RESEND_API_KEY=<broker-injected-at-deploy>   # never commit; credential rail

# Invocation secret for the parcel-health Edge Function. Boot-validated; the function
# refuses to start if unset. Sent by the cron (future slice) as the x-parcel-health-secret
# request header (custom header, NOT Authorization). Generated per environment; never committed.
PARCEL_HEALTH_PROBE_SECRET=<32-byte-random-placeholder>
